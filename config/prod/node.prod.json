{
  "name": "node-production-config",
  "version": "1.0.0",
  "description": "Production Node.js configuration",
  "environment": "production",
  "node": {
    "version": "22",
    "options": {
      "max-old-space-size": 512,
      "optimize-for-size": true,
      "use-strict": true
    },
    "flags": [
      "--enable-source-maps",
      "--no-warnings",
      "--unhandled-rejections=strict"
    ]
  },
  "performance": {
    "memory": {
      "heap_size_limit": "512MB",
      "max_old_generation_size": "400MB"
    },
    "cpu": {
      "max_workers": 2,
      "worker_threads": true
    }
  },
  "security": {
    "tls": {
      "min_version": "TLSv1.2",
      "max_version": "TLSv1.3",
      "reject_unauthorized": true
    },
    "headers": {
      "x-powered-by": false,
      "x-frame-options": "DENY",
      "x-content-type-options": "nosniff"
    }
  },
  "logging": {
    "level": "warn",
    "format": "json",
    "timestamp": true
  },
  "monitoring": {
    "health_check": {
      "enabled": true,
      "interval": 30000,
      "timeout": 10000,
      "path": "/health"
    }
  }
}
